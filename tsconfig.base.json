{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": false,
    "noImplicitAny": true,
    "strictNullChecks": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "noUncheckedIndexedAccess": false,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@interview/shared": ["./packages/shared/src/index.ts"],
      "@interview/shared/*": ["./packages/shared/src/*"],
      "@interview/db-schema": ["./packages/db-schema/src/index.ts"],
      "@interview/db-schema/*": ["./packages/db-schema/src/*"],
      "@interview/temporal": ["./packages/temporal/src/index.ts"],
      "@interview/temporal/*": ["./packages/temporal/src/*"],
      "@interview/test-kit": ["./packages/test-kit/src/index.ts"],
      "@interview/test-kit/*": ["./packages/test-kit/src/*"],
      "@interview/thalamus": ["./packages/thalamus/src/index.ts"],
      "@interview/thalamus/*": ["./packages/thalamus/src/*"],
      "@interview/sweep": ["./packages/sweep/src/index.ts"],
      "@interview/sweep/*": ["./packages/sweep/src/*"]
    }
  }
}
