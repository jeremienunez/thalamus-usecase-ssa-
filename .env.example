# Copy to .env.local and fill in. NEVER commit real values.

# LLM providers (at least one required for cloud mode)
OPENAI_API_KEY=
MOONSHOT_API_KEY=
PERPLEXITY_API_KEY=
VOYAGE_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=8192

# Local mode (Ollama for Gemma 4)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:4b-q4_K_M

# Execution mode: cloud | fixtures | record
THALAMUS_MODE=cloud

# Infra
DATABASE_URL=postgres://thalamus:thalamus@localhost:5433/thalamus
REDIS_URL=redis://localhost:6380

# Seed source
CELESTRAK_URL=https://celestrak.org/NORAD/elements/gp.php?GROUP=active&FORMAT=tle
SEED_COUNT=500

# Observability
LOG_LEVEL=info
METRICS_PORT=9464
