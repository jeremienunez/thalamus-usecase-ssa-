flowchart TB
    subgraph APP["App domain pack"]
        direction TB
        Skills["skills/*.md<br/>frontmatter + prompt body"]
        Data["CortexDataProvider<br/>sqlHelper name -> fetcher"]
        Sources["SourceFetcherPort impl<br/>structured external rows"]
        Domain["DomainConfig<br/>rules, prompts, fallbacks"]
    end

    subgraph KERNEL["packages/thalamus"]
        direction TB
        Registry["CortexRegistry<br/>discovers skill files"]
        Strategy["Execution strategies<br/>Strategist first, Standard fallback"]
        Payload["sanitize + preSummarize<br/>mode and sourcing rules"]
        LLM["LLM transport<br/>provider chain + overrides"]
    end

    Skills --> Registry
    Domain --> Strategy
    Registry --> Strategy
    Strategy --> Data
    Strategy --> Sources
    Strategy --> Payload
    Payload --> LLM
