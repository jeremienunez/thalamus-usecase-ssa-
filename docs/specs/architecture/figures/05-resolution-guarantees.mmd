flowchart TD
    Accept["Reviewer: ACCEPT"]
    Reject["Reviewer: REJECT"]

    Accept --> Preflight["Preflight<br/>accepted + payload + non-terminal"]
    Preflight --> Lock["Redis resolution lock<br/>PX 30s, NX token"]
    Lock --> Reload["Reload suggestion<br/>repeat preflight"]
    Reload --> Dispatch["ResolutionHandlerRegistry<br/>app-owned handlers"]
    Dispatch --> Promote["Promotion/audit adapter<br/>app-owned durable effects"]
    Promote --> Result["success / partial terminal<br/>failed retryable"]
    Result --> Unlock["token-checked unlock"]
    Unlock --> Signal["Store review feedback<br/>available to later audits"]

    Reject --> Log["Log rejection<br/>+ reviewer rationale"]
    Log --> SignalR["Store reviewer rationale<br/>available to later audits"]
