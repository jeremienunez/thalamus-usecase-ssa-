{
  "$comment": "Bus-class priors for the 8 sim-fish-inferable telemetry scalars (SPEC-SW-006 infer_telemetry turn action). Every entry is sourced from public operator / manufacturer datasheets or peer-reviewed papers. Fields absent from the datasheet stay null — we do NOT synthesize operator-internal numbers. Ranges are [min, typical, max] where available; single values mean the datasheet quotes one number. Units are explicit. See `sources[]` per bus for citations.",

  "$schemaVersion": 1,

  "$fields": {
    "powerDraw": {
      "unit": "W",
      "interpretation": "Average bus + payload draw at end-of-life equinox, continuous."
    },
    "thermalMargin": {
      "unit": "C",
      "interpretation": "Operating temperature margin above minimum design — delta between coldest-case payload temperature and its survival minimum."
    },
    "pointingAccuracy": {
      "unit": "deg",
      "interpretation": "3-sigma pointing knowledge on payload boresight. Lower is better."
    },
    "attitudeRate": {
      "unit": "deg/s",
      "interpretation": "Max commanded slew rate the bus ADCS can sustain without saturation."
    },
    "linkBudget": {
      "unit": "dBW",
      "interpretation": "Downlink EIRP, typical beam. Comms-class only."
    },
    "dataRate": {
      "unit": "Mbps",
      "interpretation": "Aggregate user-data throughput per bus, EOL."
    },
    "payloadDuty": {
      "unit": "fraction",
      "interpretation": "Typical in-view duty cycle, orbit-averaged. Comms ≈ 1.0, EO ≈ 0.2-0.4, SIGINT depends on geometry."
    },
    "eclipseRatio": {
      "unit": "fraction",
      "interpretation": "Fraction of orbit in Earth shadow. Pure orbital geometry — NOT from datasheet, derived at sim-fish time from SGP4 + sun position."
    }
  },

